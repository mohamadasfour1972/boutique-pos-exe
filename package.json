{
  "name": "boutique-pos",
  "version": "1.0.0",
  "description": "Boutique POS",
  "main": "main.js",
  "author": "Mohamad",
  "scripts": {
    "build": "electron-builder --win --publish=never"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mohamad.boutiquepos",
    "productName": "BoutiquePOS",
    "files": ["index.html", "main.js"],
    "win": {
      "target": "nsis"
    },
    "nsis": {
  "oneClick": false,
  "allowToChangeInstallationDirectory": true,
  "perMachine": false
}
  }
}
